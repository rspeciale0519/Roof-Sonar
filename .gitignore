# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# supabase cli
supabase/.temp/

# transient task notes/artifacts (CLAUDE.md Rule 5)
docs/temp/

# typescript
*.tsbuildinfo
next-env.d.ts

# data drops (originals archived locally, not committed)
data/inbox/*
data/processed/*
!data/inbox/.gitkeep
!data/processed/.gitkeep

.env.local
.env

# python tooling cache (records extractors)
__pycache__/
