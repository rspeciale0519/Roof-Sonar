{
   "permissions": {
      "allow": [
         "mcp__chrome-devtools__take_snapshot",
         "mcp__chrome-devtools__take_screenshot",
         "mcp__chrome-devtools__list_network_requests",
         "mcp__chrome-devtools__list_pages",
         "mcp__chrome-devtools__list_console_messages",
         "Bash(nslookup *)"
      ]
   },
   "hooks": {
      "PreToolUse": [
         {
            "matcher": "Edit|Write",
            "hooks": [
               { "type": "command", "command": "node .claude/hooks/block-env.mjs" }
            ]
         }
      ],
      "PostToolUse": [
         {
            "matcher": "Edit|Write",
            "hooks": [
               { "type": "command", "command": "node .claude/hooks/check-loc.mjs" }
            ]
         }
      ]
   }
 }
